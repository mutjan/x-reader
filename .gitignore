# ============================================
# x-reader 项目 .gitignore
# ============================================

# ----- 系统文件 -----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ----- Python -----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# ----- 环境/配置 -----
.env
.env.local
.env.*.local
*.pem

# ----- 运行时生成的缓存文件 -----
# 这些文件由脚本自动生成，不需要提交
.processed_ids.json
.processed_tweet_ids.json
.version_counter
.batch_queue.json

# ----- 临时文件 -----
.cowork-temp/
*.tmp
*.temp
*.lock

# ----- AI处理过程中的临时文件 -----
# prompt文件和结果文件（运行时会重新生成）
*_ai_prompt.txt
*_ai_result.json
*_ai_cache.json

# ----- 日志文件 -----
*.log
*.log.*
twitter_news_struct.log

# ----- 备份文件 -----
*.backup
*.bak
*.old

# ----- 错误文件 -----
*.error
*.err

# ----- 清理备份目录 -----
# 旧的清理备份不需要提交
.cleanup_backup_*/

# ----- 其他运行时文件 -----
PYEOF

# ----- 敏感信息 -----
# 包含 token、密码等敏感信息的文件
MEMORY.md

# ----- 本地配置 -----
# OpenClaw 工作区状态
.openclaw/workspace-state.json

# ----- 可选：内容规则 -----
# 如果你希望 content_rules_v2.md 只在本地维护
# content_rules_v2.md
